# Normalize text files and store them with LF line endings.
* text=auto eol=lf

# Source and configuration files.
*.cs      text eol=lf
*.csproj  text eol=lf
*.props   text eol=lf
*.targets text eol=lf
*.sln     text eol=lf
*.ps1     text eol=lf
*.sh      text eol=lf
*.md      text eol=lf
*.json    text eol=lf
*.xml     text eol=lf
*.sql     text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf
*.[Cc]onfig text eol=lf

# Binary files.
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.pdf    binary
*.nupkg  binary
*.snupkg binary
